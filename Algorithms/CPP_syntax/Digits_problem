#include <iostream>
#include <cmath>

using namespace std;

/*
 * ============================================================
 *  ЧАСТЫЕ ОШИБКИ ПРИ РАБОТЕ С ПЕРЕМЕННЫМИ РАЗНЫХ ТИПОВ
 * ============================================================
 *
 * 1. ПЕРЕПОЛНЕНИЕ (OVERFLOW)
 *    Когда значение выходит за границы допустимого диапазона типа,
 *    результат может оказаться неожиданным. Для знаковых целых
 *    переполнение вызывает неопределённое поведение, но на практике
 *    часто наблюдается «заворачивание» к противоположной границе.
 *
 * 2. АРИФМЕТИКА ПО МОДУЛЮ
 *    При вычислении (a + b) % m, (a - b) % m, (a * b) % m можно
 *    сначала брать модуль каждого операнда – это убережёт от
 *    переполнения в промежуточных вычислениях.
 *    Остаток в C++ может быть отрицательным, поэтому после
 *    x = x % m; желательно добавить if (x < 0) x += m;
 *
 * 3. ЧИСЛА С ПЛАВАЮЩЕЙ ТОЧКОЙ
 *    Из-за двоичного представления многие десятичные дроби
 *    хранятся приближённо. Сравнивать их через == опасно.
 *    Правильнее проверять, что модуль разницы меньше заданной
 *    точности: if (fabs(a - b) < 1e-9) ...
 *    Целые числа, по модулю меньшие 2^53, double представляет точно.
 */

int main() {
    // ---------------------------------------------------------
    // Пример 1: переполнение при умножении int
    // ---------------------------------------------------------
    int a = 123456789;
    // Ошибка: умножение двух int даёт int, происходит переполнение,
    // и только потом результат (уже некорректный) приводится к long long.
    long long wrong = a * a;          // переполнение int
    // Правильно: хотя бы один операнд привести к long long до умножения
    long long correct = 1LL * a * a;  // или (long long)a * a

    cout << "Некорректный результат: " << wrong << '\n';
    cout << "Корректный результат:   " << correct << "\n\n";

    // ---------------------------------------------------------
    // Пример 2: арифметика по модулю
    // ---------------------------------------------------------
    int x = 1000000000;
    int y = 2000000000;
    int m = 1000000007;

    // Прямое сложение может переполниться, если бы не использовали модуль
    int sum = (x + y) % m;             // может переполниться до взятия модуля
    // Безопасный способ – брать модуль от каждого слагаемого
    int safe_sum = ((x % m) + (y % m)) % m;

    cout << "Сумма по модулю (может быть неверной): " << sum << '\n';
    cout << "Безопасная сумма по модулю: " << safe_sum << "\n\n";

    // Отрицательный остаток
    int negative_example = -13 % 7;     // в C++ результат -6
    if (negative_example < 0)
        negative_example += 7;          // теперь 1
    cout << "Отрицательный остаток исправлен: " << negative_example << "\n\n";

    // ---------------------------------------------------------
    // Пример 3: сравнение чисел с плавающей точкой
    // ---------------------------------------------------------
    double val = 0.3 * 3 + 0.1;
    cout << "0.3*3 + 0.1 = " << val << '\n';   // может вывести 0.999999999999...

    double expected = 1.0;
    if (val == expected)
        cout << "val == 1.0 (верно)\n";
    else
        cout << "val != 1.0 (ошибка округления)\n";

    // Корректное сравнение с допуском
    const double EPS = 1e-9;
    if (fabs(val - expected) < EPS)
        cout << "Сравнение через EPS: val равно 1.0\n";
    else
        cout << "Сравнение через EPS: val не равно 1.0\n";

    return 0;
}
